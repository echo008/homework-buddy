/* pages/dictation/dictation.wxss - 听写进行页样式 */

.dictation-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 顶部导航 */
.top-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.nav-back {
  font-size: 30rpx;
  color: var(--text-secondary);
  padding: 10rpx 0;
}

.nav-skip {
  font-size: 28rpx;
  color: var(--primary);
  font-weight: 600;
  padding: 10rpx 24rpx;
  background: var(--primary-light);
  border-radius: 999rpx;
}

.progress-bar {
  margin-bottom: 30rpx;
}

.progress-text {
  text-align: center;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
}

.progress-track {
  height: 16rpx;
  background: var(--border);
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary), var(--primary-soft));
  border-radius: 8rpx;
  transition: width 0.3s;
}

.question-card {
  text-align: center;
  padding: 60rpx 40rpx;
}

.question-prompt {
  font-size: 80rpx;
  font-weight: 800;
  color: var(--text-main);
  margin-bottom: 30rpx;
  line-height: 1.3;
  word-break: break-all;
}

.question-tags {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.tts-warning {
  padding: 16rpx 24rpx;
  background: var(--warning-light);
  color: var(--warning);
  border-radius: var(--radius);
  font-size: 26rpx;
  margin-bottom: 24rpx;
}

.replay-btn {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 48rpx;
  background: var(--primary-light);
  color: var(--primary);
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.replay-btn.playing {
  background: var(--accent-light);
  color: var(--accent);
}

.replay-icon {
  font-size: 32rpx;
}

.countdown-card {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
  padding: 16rpx;
  background: var(--warning-light);
  border-radius: var(--radius);
}

.countdown-num {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--warning);
}

.countdown-text {
  font-size: 26rpx;
  color: var(--warning);
}

.answer-card {
  flex: 1;
}

.answer-input {
  width: 100%;
  height: 120rpx;
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  padding: 0 32rpx;
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text-main);
  background: var(--bg);
}

.answer-input:focus {
  border-color: var(--primary);
}

.btn-next {
  margin-top: 32rpx;
  width: 100%;
}

/* 加载页 */
.loading-page {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
}

.loading-text {
  font-size: 32rpx;
  color: var(--text-muted);
}

/* 退出确认弹窗 */
.exit-modal {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background: #fff;
  border-radius: var(--radius-lg);
  z-index: 201;
  padding: 48rpx 40rpx;
  text-align: center;
  box-shadow: 0 24rpx 80rpx rgba(0, 0, 0, 0.15);
}

.exit-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 16rpx;
}

.exit-desc {
  font-size: 28rpx;
  color: var(--text-muted);
  margin-bottom: 40rpx;
}

.exit-actions {
  display: flex;
  gap: 20rpx;
}

.exit-actions .btn-secondary,
.exit-actions .btn-primary {
  flex: 1;
  margin: 0;
}
