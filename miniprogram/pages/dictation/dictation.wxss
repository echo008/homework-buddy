/* pages/dictation/dictation.wxss */
.dictation-page {
  min-height: 100vh;
}

.progress-bar {
  margin-bottom: 30rpx;
}

.progress-text {
  text-align: center;
  font-size: 28rpx;
  color: #888;
  margin-bottom: 16rpx;
}

.progress-track {
  height: 12rpx;
  background: #e8e8e8;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #4a90d9;
  border-radius: 6rpx;
  transition: width 0.3s;
}

.question-card {
  text-align: center;
  padding: 60rpx 30rpx;
}

.question-prompt {
  font-size: 72rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 40rpx;
}

.replay-btn {
  display: inline-block;
  padding: 16rpx 40rpx;
  background: #f0f4fa;
  color: #4a90d9;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.answer-input {
  width: 100%;
  height: 96rpx;
  border: 2rpx solid #eee;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 34rpx;
  background: #fafbfc;
}
