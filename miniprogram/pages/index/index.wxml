<!--pages/index/index.wxml - 首页：听写配置-->
<view class="container">
  <!-- 学科切换 -->
  <view class="subject-tabs">
    <view
      wx:for="{{subjectTabs}}"
      wx:key="key"
      class="tab {{subject === item.key ? 'tab-active' : ''}}"
      data-key="{{item.key}}"
      bindtap="onSubjectChange"
    >{{item.label}}</view>
  </view>

  <!-- 单元多选 -->
  <view class="card">
    <view class="section-title section-title-between">
      <text>选择单元</text>
      <text class="btn-text" wx:if="{{units.length > 0}}" bindtap="onToggleAll">{{selectedUnitIds.length === units.length ? '取消全选' : '全选'}}</text>
    </view>
    <view class="unit-grid" wx:if="{{units.length > 0}}">
      <view
        wx:for="{{units}}"
        wx:key="_id"
        class="unit-chip {{selectedUnitMap[item._id] ? 'chip-active' : ''}}"
        data-id="{{item._id}}"
        bindtap="onUnitToggle"
      >
        <text class="chip-name">{{item.name}}</text>
        <text class="chip-count">{{item.wordCount}}词</text>
      </view>
    </view>
    <view class="empty-tip" wx:else>
      <text>暂无单元数据</text>
      <view class="empty-btn" bindtap="goUnits">去创建单元</view>
    </view>
  </view>

  <!-- 听写模式 -->
  <view class="card">
    <view class="section-title">听写模式</view>
    <view class="mode-list">
      <view
        wx:for="{{modeOptions[subject]}}"
        wx:key="value"
        class="mode-item {{mode === item.value ? 'mode-active' : ''}}"
        data-value="{{item.value}}"
        bindtap="onModeChange"
      >{{item.label}}</view>
    </view>
  </view>

  <!-- 数量区间 -->
  <view class="card">
    <view class="section-title">听写数量（随机 {{wordCountRange.min}}-{{wordCountRange.max}} 个）</view>
    <view class="range-row">
      <text class="range-label">最少</text>
      <slider
        class="range-slider"
        min="5"
        max="50"
        step="1"
        value="{{countMin}}"
        block-size="22"
        activeColor="#4f46e5"
        bindchange="onMinChange"
      />
      <text class="range-value">{{countMin}}</text>
    </view>
    <view class="range-row">
      <text class="range-label">最多</text>
      <slider
        class="range-slider"
        min="5"
        max="50"
        step="1"
        value="{{countMax}}"
        block-size="22"
        activeColor="#4f46e5"
        bindchange="onMaxChange"
      />
      <text class="range-value">{{countMax}}</text>
    </view>
  </view>

  <!-- 间隔时间 -->
  <view class="card">
    <view class="section-title">每题间隔（{{interval}} 秒）</view>
    <slider
      min="3"
      max="15"
      step="1"
      value="{{interval}}"
      block-size="22"
      activeColor="#4f46e5"
      bindchange="onIntervalChange"
    />
  </view>

  <!-- 快捷入口 -->
  <view class="card">
    <view class="section-title">快捷入口</view>
    <view class="quick-grid">
      <view class="quick-item" bindtap="goPreset">
        <view class="quick-icon quick-primary">🎯</view>
        <text class="quick-label">智能选题</text>
      </view>
      <view class="quick-item" bindtap="onScan">
        <view class="quick-icon quick-accent">📷</view>
        <text class="quick-label">拍照导入</text>
      </view>
      <view class="quick-item" bindtap="onShowAddModal">
        <view class="quick-icon quick-success">✏️</view>
        <text class="quick-label">手动加词</text>
      </view>
      <view class="quick-item" bindtap="goUnits">
        <view class="quick-icon quick-warning">📚</view>
        <text class="quick-label">单元/词库</text>
      </view>
      <view class="quick-item" bindtap="goClass">
        <view class="quick-icon quick-soft">🏫</view>
        <text class="quick-label">班级共享</text>
      </view>
      <view class="quick-item" bindtap="goProfile">
        <view class="quick-icon quick-muted">👤</view>
        <text class="quick-label">我的记录</text>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-bar">
    <button class="btn-secondary" bindtap="onScan">拍照导入</button>
    <button class="btn-secondary" bindtap="onShowAddModal">手动加词</button>
  </view>
  <view class="action-bar">
    <button
      class="btn-primary btn-full"
      bindtap="onStart"
      loading="{{submitting}}"
      disabled="{{submitting || selectedUnitIds.length === 0}}"
    >开始听写</button>
  </view>

  <!-- 手动加词弹窗 -->
  <view class="modal-mask" wx:if="{{showAddModal}}" bindtap="onHideAddModal"></view>
  <view class="modal" wx:if="{{showAddModal}}">
    <view class="modal-header">
      <text class="modal-title">手动添加单词</text>
      <text class="modal-close" bindtap="onHideAddModal">✕</text>
    </view>
    <view class="modal-body">
      <view class="form-row">
        <text class="form-label">{{isEnglish ? '英文单词' : '汉字/词语'}}</text>
        <input class="form-input" value="{{addForm.word}}" data-field="word" bindinput="onAddInput" placeholder="请输入" />
      </view>
      <view class="form-row">
        <text class="form-label">中文释义</text>
        <input class="form-input" value="{{addForm.meaning}}" data-field="meaning" bindinput="onAddInput" placeholder="请输入释义" />
      </view>
      <view class="form-row" wx:if="{{isChinese}}">
        <text class="form-label">拼音</text>
        <input class="form-input" value="{{addForm.pinyin}}" data-field="pinyin" bindinput="onAddInput" placeholder="如 péng" />
      </view>
      <view class="form-row" wx:if="{{isEnglish}}">
        <text class="form-label">词性</text>
        <input class="form-input" value="{{addForm.partOfSpeech}}" data-field="partOfSpeech" bindinput="onAddInput" placeholder="如 n. / v." />
      </view>
      <view class="form-row" wx:if="{{isEnglish}}">
        <text class="form-label">音标</text>
        <input class="form-input" value="{{addForm.phonetic}}" data-field="phonetic" bindinput="onAddInput" placeholder="如 /həˈləʊ/" />
      </view>
      <view class="form-row">
        <text class="form-label">课次</text>
        <input class="form-input" type="number" value="{{addForm.lesson}}" data-field="lesson" bindinput="onAddNumberInput" placeholder="1" />
      </view>
    </view>
    <view class="modal-footer">
      <button class="btn-secondary" bindtap="onHideAddModal">取消</button>
      <button class="btn-primary" bindtap="onAddSubmit" loading="{{adding}}" disabled="{{adding}}">确认添加</button>
    </view>
  </view>
</view>
