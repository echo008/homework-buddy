/* pages/index/index.wxss - 首页样式 */

.subject-tabs {
  display: flex;
  background: #fff;
  border-radius: var(--radius);
  padding: 8rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 30rpx;
  color: var(--text-secondary);
  border-radius: 18rpx;
  transition: all 0.2s;
}

.tab-active {
  background: var(--primary);
  color: #fff;
  font-weight: 700;
}

/* 单元网格 */
.unit-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.section-title-between {
  justify-content: space-between;
}

.unit-chip {
  width: calc(33.333% - 14rpx);
  padding: 24rpx 12rpx;
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  text-align: center;
  background: var(--bg);
  transition: all 0.2s;
}

.chip-active {
  border-color: var(--primary);
  background: var(--primary-light);
}

.chip-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 8rpx;
}

.chip-count {
  display: block;
  font-size: 22rpx;
  color: var(--text-muted);
}

.empty-tip {
  text-align: center;
  padding: 40rpx 0;
  color: var(--text-muted);
  font-size: 26rpx;
}

.empty-btn {
  display: inline-block;
  margin-top: 20rpx;
  padding: 12rpx 36rpx;
  background: var(--primary);
  color: #fff;
  border-radius: 999rpx;
  font-size: 26rpx;
}

/* 模式选择 */
.mode-list {
  display: flex;
  gap: 20rpx;
}

.mode-item {
  flex: 1;
  padding: 24rpx 0;
  text-align: center;
  border: 2rpx solid var(--border);
  border-radius: var(--radius);
  font-size: 28rpx;
  color: var(--text-secondary);
  background: var(--bg);
}

.mode-active {
  border-color: var(--primary);
  background: var(--primary-light);
  color: var(--primary);
  font-weight: 700;
}

/* 数量区间 */
.range-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.range-label {
  width: 80rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.range-slider {
  flex: 1;
  margin: 0 16rpx;
}

.range-value {
  width: 60rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--primary);
}

/* 快捷入口 */
.quick-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.quick-item {
  width: calc(33.333% - 14rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 0;
  background: var(--bg);
  border-radius: var(--radius);
  transition: transform 0.15s;
}

.quick-item:active {
  transform: scale(0.96);
}

.quick-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.quick-primary { background: var(--primary-light); }
.quick-accent { background: var(--accent-light); }
.quick-success { background: #dcfce7; }
.quick-warning { background: var(--warning-light); }
.quick-soft { background: #f3e8ff; }
.quick-muted { background: #f3f4f6; }

.quick-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 600;
}

/* 操作栏 */
.action-bar {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
  padding-bottom: 40rpx;
}

.action-bar .btn-secondary {
  flex: 1;
  margin: 0;
}

.action-bar .btn-primary {
  flex: 2;
  margin: 0;
}

.btn-full {
  width: 100%;
}

/* 手动加词弹窗 */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 200;
}

.modal {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 640rpx;
  background: #fff;
  border-radius: var(--radius-lg);
  z-index: 201;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 32rpx;
  border-bottom: 1rpx solid var(--border);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-main);
}

.modal-close {
  font-size: 32rpx;
  color: var(--text-muted);
  padding: 0 10rpx;
}

.modal-body {
  padding: 20rpx 32rpx;
  max-height: 600rpx;
  overflow-y: auto;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx 40rpx;
}

.modal-footer .btn-secondary,
.modal-footer .btn-primary {
  flex: 1;
  margin: 0;
}
