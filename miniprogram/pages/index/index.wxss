/* pages/index/index.wxss - 首页样式 */

.subject-tabs {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 30rpx;
  color: #888;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.tab-active {
  background: #4a90d9;
  color: #fff;
  font-weight: 600;
}

/* 单元网格 */
.unit-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.unit-chip {
  width: calc(33.333% - 14rpx);
  padding: 24rpx 12rpx;
  border: 2rpx solid #eee;
  border-radius: 14rpx;
  text-align: center;
  background: #fafbfc;
  transition: all 0.2s;
}

.chip-active {
  border-color: #4a90d9;
  background: #e8f1fc;
}

.chip-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.chip-count {
  display: block;
  font-size: 22rpx;
  color: #999;
}

.empty-tip {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 26rpx;
}

.empty-btn {
  display: inline-block;
  margin-top: 20rpx;
  padding: 12rpx 36rpx;
  background: #4a90d9;
  color: #fff;
  border-radius: 40rpx;
  font-size: 26rpx;
}

/* 模式选择 */
.mode-list {
  display: flex;
  gap: 20rpx;
}

.mode-item {
  flex: 1;
  padding: 24rpx 0;
  text-align: center;
  border: 2rpx solid #eee;
  border-radius: 14rpx;
  font-size: 28rpx;
  color: #555;
  background: #fafbfc;
}

.mode-active {
  border-color: #4a90d9;
  background: #e8f1fc;
  color: #4a90d9;
  font-weight: 600;
}

/* 数量区间 */
.range-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.range-label {
  width: 80rpx;
  font-size: 26rpx;
  color: #888;
}

.range-slider {
  flex: 1;
  margin: 0 16rpx;
}

.range-value {
  width: 60rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #4a90d9;
}

/* 操作栏 */
.action-bar {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
  padding-bottom: 40rpx;
}

.btn-secondary {
  flex: 1;
  background: #fff;
  color: #4a90d9;
  border: 2rpx solid #4a90d9;
  border-radius: 48rpx;
  font-size: 30rpx;
  height: 88rpx;
  line-height: 84rpx;
}

.action-bar .btn-primary {
  flex: 2;
}
