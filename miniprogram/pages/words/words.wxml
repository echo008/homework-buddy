<!--pages/words/words.wxml - 单词管理页-->
<view class="container words-page">
  <!-- 单元头部 -->
  <view class="card unit-header">
    <view class="unit-title">{{unitName}}</view>
    <view class="unit-subtitle">{{subject === 'english' ? '英语' : '语文'}} · {{words.length}} 个单词</view>
  </view>

  <!-- 单词列表 -->
  <view class="card" wx:if="{{words.length > 0}}">
    <view class="word-list">
      <view class="word-item" wx:for="{{words}}" wx:key="_id">
        <view class="word-main" bindtap="playItemAudio" data-url="{{item.audioUrl}}">
          <view class="word-text">
            <text>{{item.word}}</text>
            <text class="word-speaker" wx:if="{{item.audioUrl}}">🔊</text>
          </view>
          <view class="word-meaning">{{item.meaning}}</view>
          <view class="word-extra" wx:if="{{item.phonetic || item.pinyin || item.partOfSpeech}}">
            <text class="tag tag-primary" wx:if="{{item.partOfSpeech}}">{{item.partOfSpeech}}</text>
            <text class="tag tag-accent" wx:if="{{item.phonetic}}">{{item.phonetic}}</text>
            <text class="tag tag-warning" wx:if="{{item.pinyin}}">{{item.pinyin}}</text>
          </view>
        </view>
        <view class="word-actions">
          <view class="icon-btn" bindtap="onEdit" data-id="{{item._id}}">✏️</view>
          <view class="icon-btn" bindtap="onDelete" data-id="{{item._id}}">🗑️</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="card empty-state" wx:elif="{{!loading}}">
    <text class="empty-icon">📝</text>
    <text class="empty-title">还没有单词</text>
    <text class="empty-desc">点击下方按钮添加单词，还可以录下自己的读音哦。</text>
    <button class="btn-primary empty-btn" bindtap="onAdd">添加单词</button>
  </view>

  <!-- 悬浮添加按钮 -->
  <view class="fab" bindtap="onAdd" wx:if="{{words.length > 0}}">+</view>

  <!-- 添加/编辑弹窗 -->
  <view class="modal-mask" wx:if="{{showModal}}" bindtap="onHideModal"></view>
  <view class="modal" wx:if="{{showModal}}">
    <view class="modal-header">
      <text class="modal-title">{{editing ? '编辑单词' : '添加单词'}}</text>
      <text class="modal-close" bindtap="onHideModal">✕</text>
    </view>
    <view class="modal-body">
      <view class="form-row">
        <text class="form-label">{{subject === 'english' ? '英文单词 *' : '汉字/词语 *'}}</text>
        <input class="form-input" value="{{form.word}}" data-field="word" bindinput="onInput" placeholder="请输入" />
      </view>
      <view class="form-row">
        <text class="form-label">中文释义 *</text>
        <input class="form-input" value="{{form.meaning}}" data-field="meaning" bindinput="onInput" placeholder="请输入释义" />
      </view>
      <view class="form-row" wx:if="{{subject === 'chinese'}}">
        <text class="form-label">拼音</text>
        <input class="form-input" value="{{form.pinyin}}" data-field="pinyin" bindinput="onInput" placeholder="如 péng" />
      </view>
      <view class="form-row" wx:if="{{subject === 'english'}}">
        <text class="form-label">音标</text>
        <input class="form-input" value="{{form.phonetic}}" data-field="phonetic" bindinput="onInput" placeholder="如 /həˈləʊ/" />
      </view>
      <view class="form-row" wx:if="{{subject === 'english'}}">
        <text class="form-label">词性</text>
        <input class="form-input" value="{{form.partOfSpeech}}" data-field="partOfSpeech" bindinput="onInput" placeholder="如 n. / v." />
      </view>
      <view class="form-row">
        <text class="form-label">课次</text>
        <input class="form-input" type="number" value="{{form.lesson}}" data-field="lesson" bindinput="onNumberInput" placeholder="1" />
      </view>

      <!-- 录音区 -->
      <view class="form-row">
        <text class="form-label">自定义读音</text>
        <view class="audio-row" wx:if="{{form.audioUrl}}">
          <view class="audio-play" bindtap="playFormAudio">🔊 试听</view>
          <view class="audio-remove" bindtap="removeAudio">删除</view>
        </view>
        <view
          class="record-btn {{recordState === 'recording' ? 'recording' : ''}} {{recordState === 'uploading' ? 'uploading' : ''}}"
          bindtap="toggleRecord"
        >
          <text class="record-icon">{{recordState === 'recording' ? '⏹' : '🎙'}}</text>
          <text>{{recordText}}</text>
        </view>
        <text class="record-tip">点击开始录音，再次点击结束，最长 10 秒</text>
      </view>
    </view>
    <view class="modal-footer">
      <button class="btn-secondary" bindtap="onHideModal">取消</button>
      <button class="btn-primary" bindtap="onSubmit" loading="{{submitting}}" disabled="{{submitting}}">保存</button>
    </view>
  </view>
</view>
