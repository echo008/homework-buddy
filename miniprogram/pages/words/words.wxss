/* pages/words/words.wxss - 单词管理页样式 */

.words-page {
  padding-bottom: 120rpx;
}

.unit-header {
  text-align: center;
  padding: 40rpx 32rpx;
}

.unit-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 12rpx;
}

.unit-subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.word-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.word-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: var(--bg);
  border-radius: var(--radius);
}

.word-main {
  flex: 1;
  min-width: 0;
  padding-right: 16rpx;
}

.word-text {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 8rpx;
}

.word-speaker {
  font-size: 28rpx;
  color: var(--primary);
}

.word-meaning {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.word-extra {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.word-actions {
  display: flex;
  gap: 12rpx;
}

.empty-state .empty-btn {
  width: 320rpx;
  margin-top: 16rpx;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), var(--primary-soft));
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  font-weight: 300;
  box-shadow: 0 16rpx 40rpx rgba(79, 70, 229, 0.35);
  z-index: 50;
}

.fab:active {
  transform: scale(0.96);
}

/* 录音按钮 */
.audio-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.audio-play {
  display: inline-flex;
  align-items: center;
  padding: 14rpx 28rpx;
  background: var(--primary-light);
  color: var(--primary);
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.audio-remove {
  font-size: 28rpx;
  color: var(--danger);
}

.record-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 96rpx;
  border-radius: 999rpx;
  background: var(--primary-light);
  color: var(--primary);
  font-size: 32rpx;
  font-weight: 700;
  transition: all 0.2s;
}

.record-btn.recording {
  background: var(--danger-light);
  color: var(--danger);
  animation: pulse 1.2s infinite;
}

.record-btn.uploading {
  background: var(--warning-light);
  color: var(--warning);
}

.record-icon {
  font-size: 36rpx;
}

.record-tip {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--text-muted);
  text-align: center;
}

@keyframes pulse {
  0% { transform: scale(1); }
  50% { transform: scale(1.02); }
  100% { transform: scale(1); }
}

/* 弹窗复用全局样式 */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 200;
}

.modal {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 680rpx;
  max-height: 82vh;
  background: #fff;
  border-radius: var(--radius-lg);
  z-index: 201;
  box-shadow: 0 24rpx 80rpx rgba(0, 0, 0, 0.15);
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--border);
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-main);
}

.modal-close {
  font-size: 32rpx;
  color: var(--text-muted);
  padding: 0 10rpx;
}

.modal-body {
  padding: 24rpx 32rpx;
  overflow-y: auto;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx 40rpx;
}

.modal-footer .btn-secondary,
.modal-footer .btn-primary {
  flex: 1;
  margin: 0;
}
