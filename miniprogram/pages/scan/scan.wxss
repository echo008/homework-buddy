/* pages/scan/scan.wxss */
.scan-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
}
.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}
.empty-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}
.empty-desc {
  font-size: 26rpx;
  color: #888;
  text-align: center;
  margin-bottom: 60rpx;
  padding: 0 60rpx;
}
.empty-tip {
  margin-top: 40rpx;
  font-size: 24rpx;
  color: #bbb;
}
.btn-primary {
  width: 80%;
}
