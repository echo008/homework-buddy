<!--pages/profile/profile.wxml - 我的/历史记录-->
<view class="container profile-page">
  <view class="card profile-header">
    <view class="avatar">📚</view>
    <view class="profile-name">智听小学员</view>
    <view class="profile-desc">坚持听写，每天进步一点点</view>
  </view>

  <!-- 统计 -->
  <view class="card stats-card">
    <view class="stat-item">
      <text class="stat-num">{{stats.totalTests}}</text>
      <text class="stat-label">听写次数</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.totalWords}}</text>
      <text class="stat-label">听写单词</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.avgAccuracy}}</text>
      <text class="stat-label">平均正确率%</text>
    </view>
  </view>

  <!-- 入口 -->
  <view class="card menu-card">
    <view class="menu-item" bindtap="goUnits">
      <text class="menu-icon">📚</text>
      <text class="menu-label">我的单元/词库</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goClass">
      <text class="menu-icon">🏫</text>
      <text class="menu-label">班级共享</text>
      <text class="menu-arrow">›</text>
    </view>
    <button class="menu-item share-item" open-type="share">
      <text class="menu-icon">📣</text>
      <text class="menu-label">推荐给好友</text>
      <text class="menu-arrow">›</text>
    </button>
  </view>

  <!-- 最近听写 -->
  <view class="section-title">最近听写</view>

  <view wx:if="{{logs.length > 0}}">
    <view class="card log-item" wx:for="{{logs}}" wx:key="_id" data-log="{{item}}" bindtap="onLogTap">
      <view class="log-top">
        <view class="log-subject-wrap">
          <text class="tag {{item.tagClass}}">{{item.subjectLabel}}</text>
          <text class="log-mode">{{item.modeLabel}}</text>
        </view>
        <text class="log-accuracy">{{item.accuracy}}%</text>
      </view>
      <view class="log-bottom">
        <text>{{item.correctCount}}/{{item.totalWords}} 正确</text>
        <text class="log-time">{{item.createdAtText}}</text>
      </view>
    </view>
  </view>

  <view class="card empty" wx:elif="{{!loading}}">
    <text>暂无听写记录</text>
    <text class="empty-tip">去首页开始第一次听写吧</text>
  </view>

  <!-- 历史记录详情弹窗 -->
  <view class="modal-mask" wx:if="{{showLogDetail}}" bindtap="onCloseLogDetail">
    <view class="log-modal" catchtap="noop">
      <view class="log-modal-header">
        <text class="log-modal-title">听写详情</text>
        <text class="log-modal-close" bindtap="onCloseLogDetail">✕</text>
      </view>

      <view class="log-modal-body" wx:if="{{currentLog}}">
        <view class="log-modal-info">
          <text class="log-modal-subject">{{currentLog.subjectLabel}} · {{currentLog.modeLabel}}</text>
          <text class="log-modal-time">{{currentLog.createdAtText}}</text>
        </view>

        <view class="log-modal-stats">
          <view class="log-modal-stat">
            <text class="log-modal-num">{{currentLog.totalWords}}</text>
            <text class="log-modal-label">总题数</text>
          </view>
          <view class="log-modal-stat">
            <text class="log-modal-num">{{currentLog.correctCount}}</text>
            <text class="log-modal-label">正确</text>
          </view>
          <view class="log-modal-stat">
            <text class="log-modal-num">{{currentLog.wrongCount}}</text>
            <text class="log-modal-label">错误</text>
          </view>
          <view class="log-modal-stat">
            <text class="log-modal-num">{{currentLog.accuracy}}%</text>
            <text class="log-modal-label">正确率</text>
          </view>
        </view>

        <view class="log-modal-section" wx:if="{{(currentLog.wrongWords || []).length > 0}}">
          <text class="log-modal-section-title">错题列表</text>
          <view class="log-wrong-list">
            <view class="log-wrong-item" wx:for="{{currentLog.wrongWords}}" wx:key="index">
              <text class="log-wrong-word">{{item.word}}</text>
              <text class="log-wrong-meaning" wx:if="{{item.meaning}}">{{item.meaning}}</text>
            </view>
          </view>
        </view>

        <view class="log-modal-empty" wx:else>
          <text>🎉 本次全对，没有错题</text>
        </view>
      </view>

      <view class="log-modal-footer">
        <button class="btn-secondary btn-half" bindtap="onRetryWrongLog" disabled="{{!(currentLog.wrongWords || []).length}}">重测错题</button>
        <button class="btn-primary btn-half" bindtap="onRetryLog" disabled="{{!(currentLog.questions || []).length}}">重测全部</button>
      </view>
    </view>
  </view>
</view>
