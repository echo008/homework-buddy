/* pages/profile/profile.wxss */
.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 50rpx 30rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #e8f1fc;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  margin-bottom: 20rpx;
}

.profile-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.log-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.log-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.log-subject {
  font-size: 28rpx;
  font-weight: 600;
  color: #4a90d9;
}

.log-accuracy {
  font-size: 40rpx;
  font-weight: 700;
  color: #09bb07;
}

.log-bottom {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #888;
}

.log-time {
  color: #bbb;
}

.empty {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #bbb;
}
