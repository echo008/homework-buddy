/* pages/class/class.wxss - 班级共享页样式 */

.class-page {
  padding-bottom: 120rpx;
}

.join-card {
  padding-bottom: 32rpx;
}

.join-row {
  display: flex;
  gap: 20rpx;
}

.join-input {
  flex: 1;
  text-align: center;
  letter-spacing: 8rpx;
}

.join-btn {
  width: 160rpx;
  height: 88rpx;
  line-height: 88rpx;
  margin: 0;
  padding: 0;
  font-size: 30rpx;
}

.class-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.class-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: var(--bg);
  border-radius: var(--radius);
}

.class-main {
  flex: 1;
  min-width: 0;
}

.class-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 12rpx;
}

.class-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.class-code {
  font-size: 24rpx;
  color: var(--text-muted);
}

.class-arrow {
  font-size: 48rpx;
  color: var(--text-muted);
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), var(--primary-soft));
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  font-weight: 300;
  box-shadow: 0 16rpx 40rpx rgba(79, 70, 229, 0.35);
  z-index: 50;
}

.fab:active {
  transform: scale(0.96);
}

/* 详情 */
.detail-header {
  text-align: center;
  padding: 40rpx 32rpx;
}

.detail-name {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 20rpx;
}

.detail-code-row {
  display: inline-flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 32rpx;
  background: var(--primary-light);
  border-radius: 999rpx;
  margin-bottom: 20rpx;
}

.detail-code {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--primary);
  letter-spacing: 6rpx;
}

.copy-btn {
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 600;
}

.detail-meta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.section-title-between {
  justify-content: space-between;
}

.empty-mini {
  text-align: center;
  padding: 40rpx 0;
  color: var(--text-muted);
  font-size: 26rpx;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 200;
}

.modal {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 680rpx;
  max-height: 80vh;
  background: #fff;
  border-radius: var(--radius-lg);
  z-index: 201;
  box-shadow: 0 24rpx 80rpx rgba(0, 0, 0, 0.15);
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--border);
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-main);
}

.modal-close {
  font-size: 32rpx;
  color: var(--text-muted);
  padding: 0 10rpx;
}

.modal-body {
  padding: 24rpx 32rpx;
  overflow-y: auto;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx 40rpx;
}

.modal-footer .btn-secondary,
.modal-footer .btn-primary {
  flex: 1;
  margin: 0;
}

.subject-tabs {
  display: flex;
  background: var(--bg);
  border-radius: var(--radius);
  padding: 8rpx;
}

.subject-tabs .tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 30rpx;
  color: var(--text-secondary);
  border-radius: 16rpx;
}

.subject-tabs .tab-active {
  background: var(--primary);
  color: #fff;
  font-weight: 700;
}

/* 共享单元列表 */
.share-unit-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.share-unit-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: var(--bg);
  border-radius: var(--radius);
  border: 2rpx solid transparent;
}

.share-unit-active {
  border-color: var(--primary);
  background: var(--primary-light);
}

.share-unit-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-main);
}

.btn-full {
  width: 100%;
  margin-top: 20rpx;
}

.btn-leave {
  color: var(--danger);
  border-color: var(--danger-light);
}
