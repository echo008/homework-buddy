<!-- pages/preset/preset.wxml - 智能选题页面 -->
<view class="container">
  <!-- 加载中 -->
  <block wx:if="{{loading}}">
    <view class="loading-state">
      <view class="loading-spinner"></view>
      <text class="loading-text">正在加载题库...</text>
    </view>
  </block>

  <block wx:else>
    <!-- 顶部标题 -->
    <view class="preset-header">
      <text class="preset-title">智能选题</text>
      <text class="preset-subtitle">按学段、教材、单元自动匹配听写内容</text>
    </view>

    <!-- 学段选择 -->
    <view class="filter-section">
      <text class="filter-label">学段</text>
      <view class="filter-options">
        <view
          wx:for="{{gradeLevels}}"
          wx:key="value"
          class="filter-chip {{selectedGradeLevel === item.value ? 'chip-active' : ''}}"
          data-value="{{item.value}}"
          bindtap="onGradeChange"
        >
          {{item.label}}
        </view>
      </view>
    </view>

    <!-- 学科选择 -->
    <view class="filter-section">
      <text class="filter-label">科目</text>
      <view class="filter-options">
        <view
          wx:for="{{subjects}}"
          wx:key="value"
          class="filter-chip {{selectedSubject === item.value ? 'chip-active' : ''}}"
          data-value="{{item.value}}"
          bindtap="onSubjectChange"
        >
          {{item.label}}
        </view>
      </view>
    </view>

    <!-- 教材版本 -->
    <view class="filter-section" wx:if="{{versions.length > 0}}">
      <text class="filter-label">教材版本</text>
      <view class="filter-options">
        <view
          wx:for="{{versions}}"
          wx:key="value"
          class="filter-chip {{selectedVersion === item.value ? 'chip-active' : ''}}"
          data-value="{{item.value}}"
          bindtap="onVersionChange"
        >
          {{item.label}}
        </view>
      </view>
    </view>

    <!-- 内容类型 -->
    <view class="filter-section" wx:if="{{contentTypes.length > 0}}">
      <text class="filter-label">内容类型</text>
      <view class="filter-options">
        <view
          wx:for="{{contentTypes}}"
          wx:key="value"
          wx:if="{{!item.subject || item.subject === selectedSubject}}"
          class="filter-chip {{selectedContentType === item.value ? 'chip-active' : ''}}"
          data-value="{{item.value}}"
          bindtap="onContentTypeChange"
        >
          {{item.label}}
        </view>
      </view>
    </view>

    <!-- 教材列表 -->
    <view class="section-card" wx:if="{{textbooks.length > 0}}">
      <view class="section-title">选择教材</view>
      <scroll-view scroll-y class="textbook-list">
        <view
          wx:for="{{textbooks}}"
          wx:key="_id"
          class="textbook-item {{selectedTextbook && selectedTextbook._id === item._id ? 'item-active' : ''}}"
          data-item="{{item}}"
          bindtap="onTextbookSelect"
        >
          <text class="textbook-name">{{item.name}}</text>
          <text class="textbook-info">{{item.publisher}}</text>
        </view>
      </scroll-view>
    </view>

    <!-- 空教材提示 -->
    <view class="empty-state" wx:if="{{!loading && textbooks.length === 0}}">
      <text class="empty-icon">📚</text>
      <text class="empty-title">暂无匹配教材</text>
      <text class="empty-desc">换个学段或版本试试，或使用下方自定义输入</text>
    </view>

    <!-- 单元列表 -->
    <view class="section-card" wx:if="{{selectedTextbook && units.length > 0}}">
      <view class="section-header">
        <text class="section-title">选择单元</text>
        <text class="section-action" bindtap="onToggleAll">
          {{selectedUnitIds.length === units.length && units.length > 0 ? '取消全选' : '全选'}}
        </text>
      </view>
      <view class="unit-grid">
        <view
          wx:for="{{units}}"
          wx:key="_id"
          class="unit-chip {{selectedUnitMap[item._id] ? 'chip-active' : ''}}"
          data-id="{{item._id}}"
          bindtap="onUnitToggle"
        >
          <text class="chip-name">{{item.name}}</text>
          <text class="chip-count">{{item.wordCount || 0}}词</text>
        </view>
      </view>
    </view>

    <!-- 已选汇总 -->
    <view class="summary-bar" wx:if="{{selectedUnitIds.length > 0}}">
      已选 {{selectedUnitIds.length}} 个单元
    </view>

    <!-- 底部操作区 -->
    <view class="action-area">
      <button
        class="btn-secondary"
        bindtap="onImport"
        loading="{{importing}}"
        disabled="{{importing || selectedUnitIds.length === 0}}"
      >
        导入到我的单元
      </button>
      <button
        class="btn-primary"
        bindtap="onStartDictation"
        loading="{{submitting}}"
        disabled="{{submitting || selectedUnitIds.length === 0}}"
      >
        直接开始听写
      </button>
    </view>

    <!-- 自定义输入入口 -->
    <view class="custom-input-bar">
      <text class="custom-text">没找到想要的内容？</text>
      <text class="custom-link" bindtap="goCustomInput">拍照导入 / 手动输入</text>
    </view>
  </block>
</view>
