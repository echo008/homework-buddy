/* pages/result/result.wxss - 结果批改页样式 */

.result-page {
  padding-bottom: 60rpx;
}

.score-card {
  text-align: center;
  padding: 50rpx 30rpx;
}

.score-circle-wrapper {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}

.score-circle {
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: conic-gradient(var(--primary) var(--accuracy), var(--border) 0);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  animation: rotateIn 0.8s ease-out;
}

.score-inner {
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: baseline;
  justify-content: center;
  box-shadow: inset 0 0 20rpx rgba(0, 0, 0, 0.04);
}

.score-num {
  font-size: 96rpx;
  font-weight: 800;
  color: var(--primary);
}

.score-unit {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--primary);
}

.score-summary {
  display: flex;
  justify-content: space-around;
  margin-bottom: 24rpx;
}

.summary-item {
  display: flex;
  flex-direction: column;
}

.summary-num {
  font-size: 48rpx;
  font-weight: 800;
  color: var(--text-main);
}

.summary-num.correct {
  color: var(--accent);
}

.summary-num.wrong {
  color: var(--danger);
}

.summary-label {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

.score-rating {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--primary);
}

.wrong-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.wrong-item:last-child {
  border-bottom: none;
}

.wrong-q {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-main);
  flex: 1;
  padding-right: 20rpx;
  word-break: break-all;
}

.wrong-a {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  font-size: 24rpx;
}

.wrong-user {
  color: var(--danger);
  margin-bottom: 6rpx;
}

.wrong-correct {
  color: var(--accent);
}

.empty-wrong {
  text-align: center;
  padding: 60rpx 0;
  color: var(--accent);
  font-size: 32rpx;
  font-weight: 700;
}

.empty-icon {
  display: block;
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.action-bar {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.action-bar .btn-secondary,
.action-bar .btn-primary {
  flex: 1;
  margin: 0;
}

.btn-share {
  width: 100%;
  margin-top: 20rpx;
}

@keyframes rotateIn {
  from { transform: rotate(-90deg); opacity: 0; }
  to { transform: rotate(0); opacity: 1; }
}
