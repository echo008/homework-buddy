/* pages/result/result.wxss */
.result-page {
  padding-bottom: 40rpx;
}

.score-card {
  text-align: center;
  padding: 50rpx 30rpx;
}

.score-circle {
  display: inline-flex;
  align-items: baseline;
  justify-content: center;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4a90d9, #6ab0f3);
  color: #fff;
  margin-bottom: 40rpx;
}

.score-num {
  font-size: 96rpx;
  font-weight: 700;
}

.score-unit {
  font-size: 36rpx;
}

.score-summary {
  display: flex;
  justify-content: space-around;
}

.summary-item {
  display: flex;
  flex-direction: column;
}

.summary-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #333;
}

.summary-num.correct {
  color: #09bb07;
}

.summary-num.wrong {
  color: #e64340;
}

.summary-label {
  font-size: 24rpx;
  color: #888;
  margin-top: 8rpx;
}

.wrong-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.wrong-item:last-child {
  border-bottom: none;
}

.wrong-q {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.wrong-a {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  font-size: 24rpx;
}

.wrong-user {
  color: #e64340;
}

.wrong-correct {
  color: #09bb07;
  margin-top: 6rpx;
}

.empty-wrong {
  text-align: center;
  padding: 60rpx 0;
  color: #09bb07;
  font-size: 30rpx;
}

.action-bar {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.btn-secondary {
  flex: 1;
  background: #fff;
  color: #4a90d9;
  border: 2rpx solid #4a90d9;
  border-radius: 48rpx;
  font-size: 30rpx;
  height: 88rpx;
  line-height: 84rpx;
}

.action-bar .btn-primary {
  flex: 1;
}
