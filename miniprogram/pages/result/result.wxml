<!--pages/result/result.wxml - 结果批改页-->
<view class="container result-page">
  <!-- 成绩概览 -->
  <view class="card score-card">
    <view class="score-circle">
      <text class="score-num">{{accuracy}}</text>
      <text class="score-unit">%</text>
    </view>
    <view class="score-summary">
      <view class="summary-item">
        <text class="summary-num correct">{{correctCount}}</text>
        <text class="summary-label">答对</text>
      </view>
      <view class="summary-item">
        <text class="summary-num wrong">{{wrongCount}}</text>
        <text class="summary-label">答错</text>
      </view>
      <view class="summary-item">
        <text class="summary-num">{{total}}</text>
        <text class="summary-label">总数</text>
      </view>
    </view>
  </view>

  <!-- 错题列表 -->
  <view class="card" wx:if="{{wrongWords.length > 0}}">
    <view class="section-title">错题本（{{wrongWords.length}}）</view>
    <view class="wrong-item" wx:for="{{wrongWords}}" wx:key="wordId">
      <view class="wrong-q">{{item.word}}</view>
      <view class="wrong-a">
        <text class="wrong-user">你：{{item.userAnswer || '未作答'}}</text>
        <text class="wrong-correct">正确：{{item.correctAnswer}}</text>
      </view>
    </view>
  </view>

  <view class="card empty-wrong" wx:elif="{{total > 0}}">
    <text>🎉 全部答对，太棒了！</text>
  </view>

  <!-- 操作 -->
  <view class="action-bar">
    <button class="btn-secondary" bindtap="onBackHome">返回首页</button>
    <button class="btn-primary" bindtap="onRetryWrong" wx:if="{{wrongWords.length > 0}}">重测错题</button>
  </view>
</view>
