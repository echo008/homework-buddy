/* pages/units/units.wxss - 单元管理页样式 */

.units-page {
  padding-bottom: 120rpx;
}

.subject-tabs {
  display: flex;
  background: #fff;
  border-radius: var(--radius);
  padding: 8rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 30rpx;
  color: var(--text-secondary);
  border-radius: 18rpx;
  transition: all 0.2s;
}

.tab-active {
  background: var(--primary);
  color: #fff;
  font-weight: 700;
}

.unit-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.unit-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: var(--bg);
  border-radius: var(--radius);
}

.unit-info {
  flex: 1;
  min-width: 0;
  padding-right: 16rpx;
}

.unit-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 12rpx;
}

.unit-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.unit-extra {
  font-size: 24rpx;
  color: var(--text-muted);
}

.unit-actions {
  display: flex;
  gap: 12rpx;
}

.icon-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.empty-state .empty-btn {
  width: 320rpx;
  margin-top: 16rpx;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), var(--primary-soft));
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  font-weight: 300;
  box-shadow: 0 16rpx 40rpx rgba(79, 70, 229, 0.35);
  z-index: 50;
}

.fab:active {
  transform: scale(0.96);
}

/* 弹窗复用全局样式 */
.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 200;
}

.modal {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 680rpx;
  max-height: 80vh;
  background: #fff;
  border-radius: var(--radius-lg);
  z-index: 201;
  box-shadow: 0 24rpx 80rpx rgba(0, 0, 0, 0.15);
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--border);
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-main);
}

.modal-close {
  font-size: 32rpx;
  color: var(--text-muted);
  padding: 0 10rpx;
}

.modal-body {
  padding: 24rpx 32rpx;
  overflow-y: auto;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx 40rpx;
}

.modal-footer .btn-secondary,
.modal-footer .btn-primary {
  flex: 1;
  margin: 0;
}
