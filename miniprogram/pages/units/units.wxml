<!--pages/units/units.wxml - 单元管理页-->
<view class="container units-page">
  <!-- 学科切换 -->
  <view class="subject-tabs">
    <view
      wx:for="{{subjectTabs}}"
      wx:key="key"
      class="tab {{subject === item.key ? 'tab-active' : ''}}"
      data-key="{{item.key}}"
      bindtap="onSubjectChange"
    >{{item.label}}</view>
  </view>

  <!-- 单元列表 -->
  <view class="card" wx:if="{{units.length > 0}}">
    <view class="section-title">我的单元</view>
    <view class="unit-list">
      <view class="unit-item" wx:for="{{units}}" wx:key="_id">
        <view class="unit-info" bindtap="goWords" data-id="{{item._id}}" data-name="{{item.name}}" data-subject="{{item.subject}}">
          <text class="unit-name">{{item.name}}</text>
          <view class="unit-meta">
            <text class="tag tag-primary">{{item.wordCount || 0}} 词</text>
            <text class="unit-extra" wx:if="{{item.textbook}}">{{item.textbook}}</text>
          </view>
        </view>
        <view class="unit-actions">
          <view class="icon-btn" bindtap="goWords" data-id="{{item._id}}" data-name="{{item.name}}" data-subject="{{item.subject}}">📖</view>
          <view class="icon-btn" bindtap="onEdit" data-unit="{{item}}">✏️</view>
          <view class="icon-btn" bindtap="onDelete" data-id="{{item._id}}" data-name="{{item.name}}">🗑️</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="card empty-state" wx:elif="{{!loading}}">
    <text class="empty-icon">📂</text>
    <text class="empty-title">还没有单元</text>
    <text class="empty-desc">点击下方按钮创建第一个单元，然后在里面添加单词。</text>
    <button class="btn-primary empty-btn" bindtap="onAdd">创建单元</button>
  </view>

  <!-- 悬浮添加按钮 -->
  <view class="fab" bindtap="onAdd" wx:if="{{units.length > 0}}">+</view>

  <!-- 创建/编辑弹窗 -->
  <view class="modal-mask" wx:if="{{showModal}}" bindtap="onHideModal"></view>
  <view class="modal" wx:if="{{showModal}}">
    <view class="modal-header">
      <text class="modal-title">{{editing ? '编辑单元' : '新建单元'}}</text>
      <text class="modal-close" bindtap="onHideModal">✕</text>
    </view>
    <view class="modal-body">
      <view class="form-row">
        <text class="form-label">单元名称 *</text>
        <input class="form-input" value="{{form.name}}" data-field="name" bindinput="onInput" placeholder="如 Unit 1" />
      </view>
      <view class="form-row">
        <text class="form-label">教材/年级</text>
        <input class="form-input" value="{{form.grade}}" data-field="grade" bindinput="onInput" placeholder="如 三年级上册" />
      </view>
      <view class="form-row">
        <text class="form-label">学期</text>
        <input class="form-input" value="{{form.semester}}" data-field="semester" bindinput="onInput" placeholder="如 上学期" />
      </view>
      <view class="form-row">
        <text class="form-label">教材版本</text>
        <input class="form-input" value="{{form.textbook}}" data-field="textbook" bindinput="onInput" placeholder="如 人教版" />
      </view>
      <view class="form-row">
        <text class="form-label">排序号</text>
        <input class="form-input" type="number" value="{{form.order}}" data-field="order" bindinput="onNumberInput" placeholder="数字越小越靠前" />
      </view>
    </view>
    <view class="modal-footer">
      <button class="btn-secondary" bindtap="onHideModal">取消</button>
      <button class="btn-primary" bindtap="onSubmit" loading="{{submitting}}" disabled="{{submitting}}">保存</button>
    </view>
  </view>
</view>
