/* app.wxss - 全局设计系统（儿童友好、简洁大气） */
page {
  --primary: #4f46e5;
  --primary-light: #e0e7ff;
  --primary-soft: #6366f1;
  --accent: #10b981;
  --accent-light: #d1fae5;
  --warning: #f59e0b;
  --warning-light: #fef3c7;
  --danger: #ef4444;
  --danger-light: #fee2e2;
  --text-main: #1e293b;
  --text-secondary: #64748b;
  --text-muted: #94a3b8;
  --bg: #f8fafc;
  --card: #ffffff;
  --border: #e2e8f0;
  --shadow: 0 8rpx 30rpx rgba(79, 70, 229, 0.08);
  --radius: 24rpx;
  --radius-lg: 36rpx;

  background-color: var(--bg);
  color: var(--text-main);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 30rpx;
  line-height: 1.5;
  box-sizing: border-box;
}

view, text, button, input, textarea, label {
  box-sizing: border-box;
}

.container {
  padding: 30rpx;
  padding-bottom: 60rpx;
}

.card {
  background: var(--card);
  border-radius: var(--radius);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
  color: var(--text-main);
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-title-icon {
  font-size: 36rpx;
}

/* 主按钮：大圆角、高触控 */
.btn-primary {
  background: linear-gradient(135deg, var(--primary), var(--primary-soft));
  color: #fff;
  border-radius: 999rpx;
  font-size: 34rpx;
  font-weight: 700;
  height: 96rpx;
  line-height: 96rpx;
  box-shadow: 0 12rpx 32rpx rgba(79, 70, 229, 0.25);
  transition: transform 0.15s;
}

.btn-primary:active {
  transform: scale(0.98);
}

.btn-primary[disabled] {
  background: #c7d2fe;
  box-shadow: none;
  color: #fff;
}

/* 次要按钮 */
.btn-secondary {
  background: #fff;
  color: var(--primary);
  border: 2rpx solid var(--primary-light);
  border-radius: 999rpx;
  font-size: 32rpx;
  font-weight: 600;
  height: 88rpx;
  line-height: 84rpx;
}

.btn-secondary:active {
  background: var(--primary-light);
}

/* 文字按钮 */
.btn-text {
  background: transparent;
  color: var(--primary);
  font-size: 28rpx;
  font-weight: 600;
  padding: 16rpx 24rpx;
}

/* 小标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.tag-primary { background: var(--primary-light); color: var(--primary); }
.tag-accent { background: var(--accent-light); color: #15803d; }
.tag-warning { background: var(--warning-light); color: #b45309; }
.tag-danger { background: var(--danger-light); color: #b91c1c; }

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  text-align: center;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-bottom: 32rpx;
}

/* 表单 */
.form-row {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  border: 2rpx solid var(--border);
  border-radius: 18rpx;
  font-size: 30rpx;
  background: #fff;
}

.form-input:focus {
  border-color: var(--primary);
}

/* 列表项 */
.list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.list-item:last-child {
  border-bottom: none;
}

.list-item-main {
  flex: 1;
  overflow: hidden;
}

.list-item-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 6rpx;
}

.list-item-desc {
  font-size: 24rpx;
  color: var(--text-muted);
}

.list-item-actions {
  display: flex;
  gap: 16rpx;
}

.icon-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}
