/* app.wxss - 全局样式 */
page {
  --primary-color: #4a90d9;
  --primary-light: #e8f1fc;
  --danger-color: #e64340;
  --success-color: #09bb07;
  --text-primary: #333;
  --text-secondary: #888;
  --bg-color: #f5f6f8;
  --card-bg: #fff;
  --border-color: #eee;

  background-color: var(--bg-color);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  box-sizing: border-box;
}

view, text, button, input, textarea {
  box-sizing: border-box;
}

.container {
  padding: 30rpx;
}

.card {
  background-color: var(--card-bg);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.btn-primary {
  background-color: var(--primary-color);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
}

.btn-primary[disabled] {
  background-color: #b0c8e8;
  color: #fff;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  color: var(--text-primary);
}
